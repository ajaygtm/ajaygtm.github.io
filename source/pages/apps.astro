---
import {SITE} from '~/config.mjs';
import Layout from '~/layouts/PageLayout.astro';

const meta = {
	title: `Apps — ${SITE.name}`,
	description: 'This site now focuses on Ajay Gautam\'s projects, experience, and professional work.',
};
---

<Layout {meta}>
	<section class="max-w-4xl mx-auto px-6 py-16 md:py-24">
		<h1 class="text-4xl md:text-6xl font-bold leading-tighter tracking-tighter mb-6 font-heading">Apps</h1>
		<p class="text-lg md:text-xl text-gray-700 dark:text-slate-300 mb-6">The cloned app catalog was removed during the portfolio cleanup.</p>
		<p class="text-lg md:text-xl text-gray-700 dark:text-slate-300 mb-10">This site now focuses on Ajay Gautam's projects, certifications, and experience. Use the projects page for current work.</p>
		<a href="/projects" class="inline-flex items-center rounded-2xl bg-primary-600 px-6 py-3 text-white hover:bg-primary-700">View projects</a>
	</section>
</Layout>
