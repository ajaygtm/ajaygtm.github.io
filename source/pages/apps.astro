---
import {Icon} from 'astro-iconify';
import {SITE} from '~/config.mjs';
import Layout from '~/layouts/PageLayout.astro';

const meta = {
	title: `Apps — ${SITE.name}`,
	description: 'A curated list of apps built by Ajay Gautam',
};

const apps = [
	{
		title: 'CleanCalc',
		summary: 'Everyday math, beautifully simple.',
		stack: ['Firefox Extension', 'Everyday Math'],
		icon: 'tabler:calculator',
		href: 'https://github.com/ajaygtm/cleancalc',
	},
	{
		title: 'TipOffSchedule',
		summary: 'NBA dates, scores, no fuss.',
		stack: ['Website', 'NBA Schedules'],
		icon: 'tabler:calendar-event',
		href: 'https://tipoffschedule.com',
	},
	{
		title: 'Fresh Start',
		summary: 'Open tab, feel lighter.',
		stack: ['Firefox Extension', 'New Tab'],
		icon: 'tabler:leaf',
		href: 'https://github.com/ajaygtm/FreshStart',
	},
];
---

<Layout {meta}>
	<section class="mx-auto max-w-6xl px-4 py-12 md:py-16">
		<div class="mb-10 md:mb-14 text-center">
			<h1 class="text-4xl md:text-5xl font-bold font-heading leading-tight tracking-tight">Apps</h1>
			<p class="mt-4 text-base md:text-lg text-gray-600 dark:text-gray-300">A few things I built and continue to refine.</p>
		</div>

		<div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
			{apps.map((app, index) => (
				<article
					class="group rounded-3xl border border-gray-200/90 dark:border-slate-700/80 bg-white dark:bg-slate-900 p-6 shadow-sm hover:-translate-y-1.5 hover:shadow-2xl hover:shadow-gray-300/60 dark:hover:shadow-black/40 transition-all duration-300 opacity-0 app-reveal"
					style={`animation-delay: ${index * 90}ms`}
				>
					<div class="mb-4 h-11 w-11 rounded-2xl bg-primary-100 text-primary-700 dark:bg-primary-900/40 dark:text-primary-300 flex items-center justify-center text-lg font-bold">
						{app.icon ? (
							<Icon name={app.icon} class="h-5 w-5"/>
						) : (
							app.title.charAt(0)
						)}
					</div>

					<h2 class="text-xl font-semibold mb-2 group-hover:text-primary-600 transition-colors">{app.title}</h2>
					<p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed mb-4">{app.summary}</p>

					<div class="flex flex-wrap gap-2 mb-5">
						{app.stack.map(tag => (
							<span class="text-[11px] font-medium rounded-md px-2 py-1 bg-gray-100 text-gray-700 dark:bg-slate-800 dark:text-slate-300">{tag}</span>
						))}
					</div>

					<a href={app.href} target="_blank" rel="noopener noreferrer" class="inline-flex items-center text-sm font-medium text-primary-700 dark:text-primary-300 hover:underline underline-offset-4">
						View project
					</a>
				</article>
			))}
		</div>
	</section>
</Layout>

<style>
@keyframes appReveal {
	from {
		opacity: 0;
		transform: translateY(12px) scale(0.985);
	}
	to {
		opacity: 1;
		transform: translateY(0) scale(1);
	}
}

.app-reveal {
	animation: appReveal 480ms cubic-bezier(0.2, 0.9, 0.2, 1) forwards;
}
</style>
