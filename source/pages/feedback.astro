---
import Layout from '~/layouts/PageLayout.astro';

const meta = {
	title: 'Feedback — Ajay Gautam',
};
---

<Layout {meta}>
	<section class="max-w-3xl mx-auto px-6 py-16">
		<h1 class="text-4xl md:text-5xl font-bold leading-tighter tracking-tighter mb-6 font-heading">Feedback</h1>
		<p class="text-lg text-gray-700 dark:text-slate-300 mb-4">The old app-support workflow was removed during the site cleanup.</p>
		<p class="text-lg text-gray-700 dark:text-slate-300 mb-8">For questions, collaboration, or project feedback, use the contact page and include the relevant context.</p>
		<a href="/contact" class="inline-flex items-center rounded-2xl bg-primary-600 px-6 py-3 text-white hover:bg-primary-700">Go to contact</a>
	</section>
</Layout>
