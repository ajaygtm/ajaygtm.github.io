---
import Layout from '~/layouts/PageLayout.astro';
import {SITE} from '~/config.mjs';

const meta = {
	title: `Moved to Apps — ${SITE.name}`,
	description: 'The Projects page has moved to /apps.',
};
---

<Layout {meta}>
	<section class="mx-auto max-w-3xl px-6 py-16 text-center">
		<h1 class="text-4xl md:text-5xl font-bold font-heading leading-tight tracking-tight">Moved to Apps</h1>
		<p class="mt-4 text-base md:text-lg text-gray-600 dark:text-gray-300">This page now lives at /apps.</p>
		<a href="/apps" class="inline-flex mt-8 items-center rounded-2xl bg-primary-600 px-6 py-3 text-white hover:bg-primary-700">Go to Apps</a>
	</section>
</Layout>
